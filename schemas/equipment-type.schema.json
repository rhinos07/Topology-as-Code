{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://topology-as-code.internal/schemas/equipment-type.schema.json",
  "title": "Equipment Type",
  "description": "Catalog entry describing a class of equipment (forklift, shuttle, AGV) and its capabilities.",
  "type": "object",
  "required": ["id", "automation_level"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9_]+$",
      "description": "Unique ID, e.g. 'shuttle_4way'"
    },
    "description": { "type": "string" },
    "automation_level": {
      "type": "string",
      "enum": ["manual", "conveyor_automated", "mixed"]
    },
    "max_payload": { "$ref": "quantity.schema.json#/definitions/mass" },
    "max_speed": { "$ref": "quantity.schema.json#/definitions/speed" }
  },
  "additionalProperties": false
}
