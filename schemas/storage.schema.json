{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://warehouse-as-code.internal/schemas/storage.schema.json",
  "title": "Warehouse Storage Structure",
  "type": "object",
  "required": ["storage_types"],
  "properties": {
    "storage_types": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "storage-type.schema.json" }
    },
    "activity_areas": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "activity", "bins_from"],
        "properties": {
          "id": { "type": "string", "pattern": "^[A-Z0-9_]+$" },
          "activity": { "type": "string", "minLength": 1 },
          "bins_from": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": { "type": "string", "minLength": 1 }
          }
        },
        "additionalProperties": false
      }
    },
    "work_centers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "step"],
        "properties": {
          "id": { "type": "string", "pattern": "^[A-Z0-9_]+$" },
          "step": { "type": "string", "minLength": 1 },
          "workstation_template": { "type": "string", "minLength": 1 },
          "storage_point_ref": { "type": "boolean" }
        },
        "additionalProperties": false
      }
    },
    "doors": {
      "type": "array",
      "items": { "$ref": "door.schema.json" }
    }
  },
  "additionalProperties": false
}
