{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://topology-as-code.internal/schemas/hazmat-class.schema.json",
  "title": "Hazmat Class",
  "description": "Catalog entry describing a hazardous material / compliance classification that a storage_type can be certified or restricted for.",
  "type": "object",
  "required": ["id"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[A-Z0-9_]+$",
      "description": "Unique ID, e.g. 'GHS02_FLAMMABLE'"
    },
    "description": { "type": "string" }
  },
  "additionalProperties": false
}
