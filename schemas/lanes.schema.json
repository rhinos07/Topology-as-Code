{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://topology-as-code.internal/schemas/lanes.schema.json",
  "title": "Lanes",
  "description": "Physical connectivity between storage_types, doors and work_centers ('can') - see strategies/movement_rules.yaml for functional permission ('may').",
  "type": "object",
  "properties": {
    "connections": {
      "type": "array",
      "description": "Explicit physical can-edges, especially for manual walking, forklift and tugger routes. Functional permission remains in movement_rules.",
      "items": {
        "type": "object",
        "required": ["id", "from", "to", "direction", "transport_mode"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "from": { "type": "string", "minLength": 1 },
          "to": { "type": "string", "minLength": 1 },
          "direction": { "type": "string", "enum": ["one_way", "bidirectional"] },
          "transport_mode": {
            "type": "string",
            "enum": ["walking", "forklift", "tugger", "amr", "conveyor"]
          },
          "expected_duration": { "$ref": "quantity.schema.json#/definitions/duration" },
          "capacity": { "type": "integer", "minimum": 1 }
        },
        "additionalProperties": false
      }
    },
    "lanes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "connects"],
        "properties": {
          "id": { "type": "string" },
          "template": {
            "type": "string",
            "description": "References an id in elements/rack_templates.yaml (lane_templates)."
          },
          "connects": {
            "type": "array",
            "items": { "type": "string" },
            "minItems": 2,
            "uniqueItems": true
          }
        },
        "additionalProperties": false
      }
    },
    "conveyor_segments": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "from", "to"],
        "properties": {
          "id": { "type": "string" },
          "from": { "type": "string" },
          "to": { "type": "string" },
          "capacity": { "type": "integer", "minimum": 1 }
        },
        "additionalProperties": false
      }
    },
    "conveyor_main": {
      "type": "object",
      "properties": {
        "connects": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 2,
          "uniqueItems": true
        },
        "capacity_units_per_hour": { "type": "integer", "minimum": 1 }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
