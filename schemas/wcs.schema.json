{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://warehouse-as-code.internal/schemas/wcs.schema.json",
  "title": "Warehouse Control System (WCS)",
  "description": "Controller definitions, reporting points, telegram actions and equipment - the communication layer between WMS and downstream control systems (PLC, MFC, AS controller, etc.).",
  "type": "object",
  "properties": {
    "controller_definitions": {
      "type": "array",
      "description": "Downstream control systems this WCS delegates tasks to - a PLC, a Material Flow Controller (MFC), a vendor-specific AS controller (e.g. AutoStore), etc.",
      "items": {
        "type": "object",
        "required": ["id"],
        "properties": {
          "id": { "type": "string" },
          "name": {
            "type": "string",
            "description": "Plant/installation name (Anlagenname)."
          },
          "reference_number": {
            "type": "string",
            "description": "Plant reference number (Anlagenreferenznummer)."
          },
          "channels": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["id"],
              "properties": {
                "id": { "type": "string" },
                "ip": { "type": "string" },
                "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
                "telegram_length": { "type": "integer", "minimum": 1 },
                "handshake_mode": { "type": "string" }
              },
              "additionalProperties": true
            }
          }
        },
        "additionalProperties": true
      }
    },
    "reporting_points": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "controller"],
        "properties": {
          "id": { "type": "string" },
          "storage_point_ref": { "type": "boolean" },
          "controller": {
            "type": "string",
            "description": "References an id in controller_definitions."
          },
          "type": {
            "type": "string",
            "enum": ["identification_point", "aisle_decision_point", "clarification_point"]
          },
          "capacity": { "type": "integer", "minimum": 1 },
          "availability": { "type": "string", "enum": ["available", "unavailable"] }
        },
        "additionalProperties": true
      }
    },
    "telegram_actions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["telegram_type", "action"],
        "properties": {
          "telegram_type": { "type": "string" },
          "action": { "type": "string" },
          "from_point": { "type": "string" },
          "to_point": { "type": "string" },
          "next_target": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "equipment": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "type", "mode"],
        "properties": {
          "id": { "type": "string" },
          "type": {
            "type": "string",
            "description": "References an id in elements/equipment_types.yaml."
          },
          "mode": {
            "type": "string",
            "enum": ["wms_controlled", "controller_autonomous"],
            "description": "wms_controlled: WMS decides the route explicitly (SAP EWM: 'Resource'). controller_autonomous: the downstream controller is autonomous with its own order buffer (SAP EWM: 'Vehicle')."
          },
          "bin_access_type": { "type": "string" },
          "served_points": {
            "type": "array",
            "items": { "type": "string" }
          },
          "fleet_interface": { "type": "string" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": false
}
