{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://warehouse-as-code.internal/schemas/rack-templates.schema.json",
  "title": "Rack, Lane and Workstation Templates",
  "type": "object",
  "properties": {
    "rack_templates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "dimensions", "max_weight"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9_]+$" },
          "description": { "type": "string" },
          "dimensions": {
            "type": "object",
            "required": ["width", "depth", "height"],
            "properties": {
              "width": { "$ref": "quantity.schema.json#/definitions/length" },
              "depth": { "$ref": "quantity.schema.json#/definitions/length" },
              "height": { "$ref": "quantity.schema.json#/definitions/length" }
            },
            "additionalProperties": false
          },
          "max_weight": { "$ref": "quantity.schema.json#/definitions/mass" },
          "temperature_zone": { "$ref": "quantity.schema.json#/definitions/temperatureZone" }
        },
        "additionalProperties": false
      }
    },
    "lane_templates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "width", "direction"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9_]+$" },
          "width": { "$ref": "quantity.schema.json#/definitions/length" },
          "direction": { "type": "string", "enum": ["unidirectional", "bidirectional"] },
          "shuttle_compatible": { "type": "boolean" },
          "max_speed": { "$ref": "quantity.schema.json#/definitions/speed" }
        },
        "additionalProperties": false
      }
    },
    "workstation_templates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "type"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9_]+$" },
          "type": { "type": "string" },
          "ergonomic_class": { "type": "string" },
          "throughput_capacity": { "type": "integer", "minimum": 1 }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
