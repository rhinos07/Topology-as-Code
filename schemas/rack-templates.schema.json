{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://topology-as-code.internal/schemas/rack-templates.schema.json",
  "title": "Lane and Workstation Templates",
  "type": "object",
  "properties": {
    "lane_templates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "width", "direction"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9_]+$" },
          "width": { "$ref": "quantity.schema.json#/definitions/length" },
          "direction": { "type": "string", "enum": ["unidirectional", "bidirectional"] },
          "shuttle_compatible": { "type": "boolean" },
          "max_speed": { "$ref": "quantity.schema.json#/definitions/speed" }
        },
        "additionalProperties": false
      }
    },
    "workstation_templates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "type"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9_]+$" },
          "type": { "type": "string" },
          "ergonomic_class": { "type": "string" },
          "throughput_capacity": { "type": "integer", "minimum": 1 }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
