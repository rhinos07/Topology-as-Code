{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://warehouse-as-code.internal/schemas/warehouse.schema.json",
  "title": "Warehouse (Building-Level)",
  "description": "A single building within a facility (see facility.schema.json). Part of the Company -> Facility -> Building hierarchy.",
  "type": "object",
  "required": ["api_version", "metadata", "target", "import_policy", "warehouse"],
  "properties": {
    "api_version": { "$ref": "import-manifest.schema.json#/properties/api_version" },
    "metadata": { "$ref": "import-manifest.schema.json#/properties/metadata" },
    "target": { "$ref": "import-manifest.schema.json#/properties/target" },
    "import_policy": { "$ref": "import-manifest.schema.json#/properties/import_policy" },
    "warehouse": {
      "type": "object",
      "required": ["name", "imports"],
      "properties": {
        "number": {
          "type": "string",
          "description": "Optional building-internal code. The facility/plant code (e.g. 'PA11') belongs on the parent facility, not here."
        },
        "name": { "type": "string" },
        "automation_level": {
          "type": "string",
          "enum": ["manual", "conveyor_automated", "mixed"]
        },
        "imports": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Relative paths to further YAML files (structure/, strategies/)."
        },
        "fleet_interface": {
          "type": "object",
          "properties": {
            "protocol": { "type": "string" },
            "version": { "type": "string" },
            "mqtt_broker": { "type": "string" },
            "node_mapping": { "type": "string" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
